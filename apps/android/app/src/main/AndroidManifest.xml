<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/pdf" />
        </intent>
    </queries>

    <application
        android:name=".MelonApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.Melon">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Melon.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Grants PDF viewers read access to the offline document slots
             under filesDir/documents (Comprovante / Histórico). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <service
            android:name=".firebase.MelonFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- "Próxima aula" home-screen widget. The receiver runs in the host
             app process; Glance handles the actual RemoteViews rendering.
             `TIME_SET` / `TIMEZONE_CHANGED` keep the countdown honest when the
             user manually changes the clock or crosses a TZ boundary —
             without these we'd render against the new wall time only on the
             next AlarmManager tick (which can be minutes away in Doze).
             Both are protected broadcasts (system-only sender). -->
        <receiver
            android:name=".widgets.NextClassWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_next_class_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/next_class_widget_info" />
        </receiver>
    </application>

</manifest>
