    <!-- Semester summary: "{classes} · {credits} · semestre {code}".
         Built by combining two plurals + the semester code. When the
         code is missing, the third clause is dropped via
         onboarding_ready_semester_summary_no_code. -->
    <string name="onboarding_ready_semester_summary_format">%1$s · %2$s · semestre %3$s</string>
    <string name="onboarding_ready_semester_summary_no_code">%1$s · %2$s</string>
    <plurals name="onboarding_ready_classes">
        <item quantity="one">%d turma</item>
        <item quantity="other">%d turmas</item>
    </plurals>
    <plurals name="onboarding_ready_credits">
        <item quantity="one">%d crédito</item>
        <item quantity="other">%d créditos</item>
    </plurals>

    <string name="onboarding_ready_next_class_label">PRÓXIMA AULA</string>

