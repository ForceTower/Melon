<?xml version="1.0" encoding="utf-8"?>
<!-- Cold-start splash icon. Static values are the FINAL (fully visible) state so
     the pre-API-31 core-splashscreen backport renders a correct still icon; the
     targets below animate it in on API 31+, echoing the in-app Compose splash
     (glyph scales up, the four melon dots pop in staggered). -->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="1024"
            android:viewportHeight="1024">
            <group
                android:name="pop"
                android:pivotX="512"
                android:pivotY="512">
                <group
                    android:scaleX="0.6"
                    android:scaleY="0.6"
                    android:translateX="204.8"
                    android:translateY="204.8">
                    <path
                        android:name="glyph"
                        android:pathData="M317,174V431C317,482.7 337.5,532.3 374.1,568.9C410.7,605.5 460.3,626 512,626C563.7,626 613.3,605.5 649.9,568.9C686.5,532.3 707,482.7 707,431V174C707,171.9 706.2,169.8 704.7,168.3C703.2,166.8 701.1,166 699,166H597V431C597,453.5 588,475.2 572.1,491.1C556.2,507 534.5,516 512,516C489.5,516 467.8,507 451.9,491.1C436,475.2 427,453.5 427,431V166H325C322.9,166 320.8,166.8 319.3,168.3C317.8,169.8 317,171.9 317,174Z"
                        android:fillColor="#FBF7F2" />
                    <path
                        android:name="dotCoral"
                        android:pathData="M268.5,858.9C302.4,858.9 329.9,831.4 329.9,797.5C329.9,763.5 302.4,736 268.5,736C234.5,736 207,763.5 207,797.5C207,831.4 234.5,858.9 268.5,858.9Z"
                        android:fillColor="#E85D4E" />
                    <path
                        android:name="dotAmber"
                        android:pathData="M431.1,858.9C465.1,858.9 492.6,831.4 492.6,797.5C492.6,763.5 465.1,736 431.1,736C397.2,736 369.7,763.5 369.7,797.5C369.7,831.4 397.2,858.9 431.1,858.9Z"
                        android:fillColor="#F4A23C" />
                    <path
                        android:name="dotMagenta"
                        android:pathData="M593.8,858.9C627.8,858.9 655.3,831.4 655.3,797.5C655.3,763.5 627.8,736 593.8,736C559.9,736 532.4,763.5 532.4,797.5C532.4,831.4 559.9,858.9 593.8,858.9Z"
                        android:fillColor="#B23A7A" />
                    <path
                        android:name="dotViolet"
                        android:pathData="M756.5,858.9C790.5,858.9 818,831.4 818,797.5C818,763.5 790.5,736 756.5,736C722.6,736 695.1,763.5 695.1,797.5C695.1,831.4 722.6,858.9 756.5,858.9Z"
                        android:fillColor="#7A6CE0" />
                </group>
            </group>
        </vector>
    </aapt:attr>

    <!-- Whole glyph scales up with an overshoot, mirroring the Compose splash's
         CubicBezier(0.2, 0.9, 0.3, 1.3) icon entrance. -->
    <target android:name="pop">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.4"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.4"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="glyph">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="60"
                android:duration="280"
                android:interpolator="@android:interpolator/decelerate_quad" />
        </aapt:attr>
    </target>

    <target android:name="dotCoral">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="220"
                android:duration="160" />
        </aapt:attr>
    </target>

    <target android:name="dotAmber">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="290"
                android:duration="160" />
        </aapt:attr>
    </target>

    <target android:name="dotMagenta">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="360"
                android:duration="160" />
        </aapt:attr>
    </target>

    <target android:name="dotViolet">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:startOffset="430"
                android:duration="160" />
        </aapt:attr>
    </target>
</animated-vector>
