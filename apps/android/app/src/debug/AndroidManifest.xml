<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only overlay: allows plain-HTTP so debug builds can talk to a
     local mock API through `adb reverse` (see API_BASE_URL in
     build.gradle.kts). Release builds keep cleartext blocked. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:usesCleartextTraffic="true" />
</manifest>
