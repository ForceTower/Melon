---
---

<section class="hero">
  <div class="hero-mesh">
    <div class="b b1"></div>
    <div class="b b2"></div>
    <div class="b b3"></div>
    <div class="b b4"></div>
  </div>

  <div class="hero-grid">
    <div>
      <div class="hero-eyebrow">
        <span class="pulse"></span>
        feito para a UEFS — Feira de Santana
      </div>
      <h1 class="hero-h1">
        Seu semestre,<br />
        <em>num só</em><br />
        lugar.
      </h1>
      <p class="hero-sub">
        Horários, notas, recados da coordenação e turmas, tudo conectado no seu celular. Sem abrir
        4 sites diferentes às 7 da manhã.
      </p>
      <div class="hero-ctas">
        <a href="#baixar" class="btn-light">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
            ></path></svg
          >
          App Store
        </a>
        <a href="#baixar" class="btn-outline-d">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M3 20.5V3.5c0-.85.45-1.59 1.13-2L13.5 12 4.13 22.5C3.45 22.09 3 21.35 3 20.5zm10.81-7.05L16.78 16 6.05 22.06l7.76-8.61zM18.16 9.94l-2.91 2.93L16.78 8 18.16 9.94zM6.05 1.94L16.78 8l-2.97 2.97L6.05 1.94z"
            ></path></svg
          >
          Google Play
        </a>
      </div>

      <div class="hero-meta">
        <div>
          <div class="num">12<em>k</em></div>
          <div class="lab">estudantes da UEFS já usam</div>
        </div>
        <div>
          <div class="num">4,9<em>★</em></div>
          <div class="lab">avaliação média nas lojas</div>
        </div>
        <div>
          <div class="num">2<em>min</em></div>
          <div class="lab">para conectar sua matrícula</div>
        </div>
      </div>
    </div>

    <div class="hero-phone-wrap">
      <div class="float-chip fc-1">
        <div>
          <span class="ch-mono">próxima aula</span>
          <span class="ch-val">Cálculo <em>II</em></span>
        </div>
      </div>
      <div class="float-chip fc-2">
        <div>
          <span class="ch-mono">coeficiente</span>
          <span class="ch-val">8<em>,</em>5</span>
        </div>
      </div>
      <div class="float-chip fc-3">
        <div>
          <span class="ch-mono">prova em</span>
          <span class="ch-val">5 <em>dias</em></span>
        </div>
      </div>

      <div class="phone">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <div class="mh-mesh"></div>
          <div class="mh-content">
            <div class="mh-eyebrow">◦ quinta · 17 abr</div>
            <div class="mh-greet">Bom dia,<br /><em>Mariana</em></div>

            <div class="mh-now">
              <div class="mh-now-eyb"><span class="d"></span> próxima aula · em 1h 12min</div>
              <div class="mh-now-title">Cálculo Diferencial II</div>
              <div class="mh-now-meta">MT-14 · Adriana Matos · 10:20–12:00</div>
            </div>

            <div class="mh-tiles">
              <div class="mh-tile">
                <div class="mh-tile-lab">◦ coeficiente</div>
                <div>
                  <div class="mh-tile-num">8<em>,</em>5</div>
                  <div class="mh-tile-sub">+0,3 vs 2025.2</div>
                </div>
              </div>
              <div class="mh-tile">
                <div class="mh-tile-lab">◦ próxima prova</div>
                <div>
                  <div class="mh-tile-num">5<em> d</em></div>
                  <div class="mh-tile-sub">P2 · Algoritmos I</div>
                </div>
              </div>
              <div class="mh-tile dark">
                <div class="mh-tile-lab">◦ mensagens</div>
                <div>
                  <div class="mh-tile-num">2</div>
                  <div class="mh-tile-sub">não lidos</div>
                </div>
              </div>
              <div class="mh-tile">
                <div class="mh-tile-lab">◦ frequência</div>
                <div>
                  <div class="mh-tile-num">96<em>%</em></div>
                  <div class="mh-tile-sub">14 dias</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
